{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "crystal-blue-window-cleaning",
  "compatibility_date": "2026-06-19",
  "routes": [
    { "pattern": "crystalbluewindowcleaning.com", "custom_domain": true },
    { "pattern": "www.crystalbluewindowcleaning.com", "custom_domain": true }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
